# --- Core ---
ENVIRONMENT=development
APP_NAME=Shift Handover System
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# --- Database ---
DATABASE_URL=postgresql+psycopg2://shift:shift@db:5432/shift

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Default admin (created on first boot) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=System Administrator

# --- Scheduler ---
# Cron: minute hour day month weekday  (default: 07:00, 15:00, 23:00 daily)
REPORT_DISPATCH_CRON=0 7,15,23 * * *
SCHEDULER_TIMEZONE=UTC
DEFAULT_MAILING_LIST=ops-team@example.com

# --- SMTP (leave SMTP_HOST blank for dry-run mode where emails are logged) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=shift-bot@example.com
SMTP_USE_TLS=true

# --- AI provider: anthropic | openai | (blank for heuristic fallback) ---
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=1200
