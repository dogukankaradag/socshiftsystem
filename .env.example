# Copy to .env and adjust before `docker compose up`.

# Postgres
POSTGRES_USER=shift
POSTGRES_PASSWORD=shift
POSTGRES_DB=shift

# Backend
ENVIRONMENT=production
JWT_SECRET=please-change-me-to-a-long-random-string-min-32-chars
CORS_ORIGINS=http://localhost:8080,http://localhost

# Varsayılan admin (ilk boot'ta oluşturulur). İlk girişten sonra parolayı
# Yönetim panelinden değiştirin.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Sistem Yoneticisi

# Scheduler — vardiya devir cron (Europe/Istanbul, sabit GMT+3)
REPORT_DISPATCH_CRON=0 7,15,23 * * *
SCHEDULER_TIMEZONE=Europe/Istanbul
DEFAULT_MAILING_LIST=ops-team@example.com

# On-prem SMTP / Exchange relay.
# SMTP_HOST boş bırakılırsa "kuru çalışma" modunda mailler sadece log'a yazılır.
# Detaylı senaryolar için MAIL_INTEGRATION_PLANI.md dosyasına bakın.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Vardiya Devir Sistemi <vardiya-devir@sirket.local>
SMTP_USE_TLS=true     # 587 (STARTTLS) için true
SMTP_USE_SSL=false    # 465 (saf TLS / SMTPS) için true

# Reminder — planlı giriş için yaklaşma e-postası.
# occurs_at zamanı yaklaşan girişler için bu kadar dakika önce,
# vardiyaya bağlı mail listesinin TO alıcılarına kısa hatırlatma gönderilir.
REMINDER_LEAD_MINUTES=30
REMINDER_TICK_SECONDS=60

# IMAP poller — DHS / İYS mailleri için otomatik veri çekme.
# IMAP_HOST boş bırakılırsa poller devre dışı kalır (yalnızca manuel giriş).
# Exchange/Outlook senaryoları: şirketin IMAP endpoint'ini (ör. mail.sirket.local
# port 993 TLS) girin, izole bir dedicated mailbox açılması önerilir.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
IMAP_POLL_SECONDS=600
# Konu/body regex'leri. İlk rakam grubu numeric_value olarak alınır.
IMAP_SUBJECT_DHS_REGEX=(?i)DHS.*?(\d{1,6})
IMAP_SUBJECT_IYS_REGEX=(?i).Y.*?case.*?(\d{1,6})

# Üçüncü parti AI / cloud servis kullanılmıyor — bu blok bilinçli olarak boş.
